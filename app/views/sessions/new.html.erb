<%= turbo_frame_tag "auth_form" do %>
  <div class="auth-form-container">
    <h1 class="auth-form-title" style="text-align: center;">Welcome back!</h1>
    <p class="auth-form-subtitle">Sign in to continue your productivity journey</p>

    <div class="auth-segmented-control">
      <%= link_to "Sign In", sign_in_path, class: "active", data: { turbo_frame: "auth_form" } %>
      <%= link_to "Sign Up", sign_up_path, data: { turbo_frame: "auth_form" } %>
    </div>

    <%= form_with url: sign_in_path, data: { turbo: true, turbo_frame: "_top" } do |f| %>
      <div class="auth-fields">
        <div class="auth-field">
          <wa-input
            label="Email address"
            name="email_address"
            type="email"
            value="<%= params[:email_address] %>"
            required
            autofocus
            autocomplete="username"
          >
            <i class="fa-light fa-envelope" style="color: var(--color-zinc-400);"></i>
          </wa-input>
        </div>

        <div class="auth-field" data-controller="password-visibility">
          <wa-input
            label="Password"
            name="password"
            type="password"
            required
            autocomplete="current-password"
            maxlength="72"
            data-password-visibility-target="input"
          >
            <i class="fa-light fa-lock" style="color: var(--color-zinc-400);"></i>
            <i
              class="fa-light fa-eye-slash"
              data-action="click->password-visibility#toggle"
              data-password-visibility-target="toggle"
              style="color: var(--color-zinc-400); cursor: pointer; padding: 4px;"
              role="button"
              tabindex="0"
              aria-label="Toggle password visibility"
            ></i>
          </wa-input>
        </div>
      </div>

      <div style="text-align: right;">
        <%= link_to "Forgot password?", new_password_path, style: "color: var(--color-primary); font-size: 13px; font-weight: 500; text-decoration: none;", data: { turbo_frame: "_top" } %>
      </div>

      <button
        class="auth-primary-btn"
        type="submit"
        data-turbo-submits-with="Signing in..."
      >
        Sign In
      </button>
    <% end %>

    <div class="auth-divider">
      <div class="auth-divider-line"></div>
      <span class="auth-divider-text">or</span>
      <div class="auth-divider-line"></div>
    </div>

    <%= render "shared/oauth_buttons" %>

    <div class="auth-prompt">
      <span>Don't have an account?</span>
      <%= link_to "Sign Up", sign_up_path, data: { turbo_frame: "auth_form" } %>
    </div>
  </div>
<% end %>
