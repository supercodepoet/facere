<div data-controller="context-menu"
  data-context-menu-item-id-value="<%= item.id %>"
  data-context-menu-list-id-value="<%= todo_list.id %>">
  <div class="dropdown-wrap" data-controller="dropdown" data-action="dropdown:select->context-menu#dispatch">
    <button type="button" class="todo-item-more" data-action="click->dropdown#toggle">
      <i class="fa-solid fa-ellipsis-vertical"></i>
    </button>
    <div class="dropdown-menu" data-dropdown-target="menu">
      <button type="button" class="dropdown-item" data-action="click->dropdown#select" data-value="edit">
        <i class="fa-light fa-pen"></i>
        Edit
      </button>
      <button type="button" class="dropdown-item" data-action="click->dropdown#select" data-value="move">
        <i class="fa-light fa-arrow-right-arrow-left"></i>
        Move...
      </button>
      <button type="button" class="dropdown-item" data-action="click->dropdown#select" data-value="copy">
        <i class="fa-light fa-copy"></i>
        Copy...
      </button>
      <hr class="dropdown-divider">
      <button type="button" class="dropdown-item" data-action="click->dropdown#select" data-value="archive">
        <i class="fa-light fa-box-archive"></i>
        Archive
      </button>
      <button type="button" class="dropdown-item dropdown-item--danger" data-action="click->dropdown#select" data-value="delete">
        <i class="fa-light fa-trash"></i>
        Delete
      </button>
      <hr class="dropdown-divider">
      <button type="button" class="dropdown-item" data-action="click->dropdown#select" data-value="insert">
        <i class="fa-light fa-plus"></i>
        Insert a to-do
      </button>
    </div>
  </div>
  <div hidden>
    <%= button_to archive_todo_list_todo_item_path(todo_list, item), method: :patch, data: { context_menu_target: "archiveForm" } %>
    <%= button_to todo_list_todo_item_path(todo_list, item), method: :delete, data: { context_menu_target: "deleteForm", turbo_confirm: "Are you sure? This cannot be undone." } %>
  </div>
</div>
