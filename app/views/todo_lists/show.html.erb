<div class="show-layout">
  <%= render "sidebar", sidebar_lists: @sidebar_lists, shared_lists: @shared_sidebar_lists, current_list: @todo_list %>

  <div class="show-main" data-controller="show-actions collaboration">
    <%= turbo_stream_from @todo_list, :updates %>
    <%= turbo_refreshes_with method: :morph, scroll: :preserve %>
    <div class="show-header">
      <div class="show-header-left">
        <%= link_to todo_lists_path, class: "show-back-btn", aria: { label: "Back to lists" } do %>
          <i class="fa-light fa-arrow-left"></i>
        <% end %>
        <div class="show-title-group">
          <% if @todo_list.icon.present? %>
            <i class="fa-light fa-<%= @todo_list.icon %> show-title-icon" style="color: var(--list-color-<%= @todo_list.color %>);"></i>
          <% end %>
          <h1 class="show-title"><%= @todo_list.name %></h1>
          <% if list_owner? %>
            <%= link_to edit_todo_list_path(@todo_list), class: "show-edit-btn", aria: { label: "Edit list" } do %>
              <i class="fa-light fa-pen"></i>
            <% end %>
          <% end %>
        </div>
      </div>

      <div class="show-header-right">
        <% if list_editor? %>
          <button class="show-action-btn show-action-btn-section" data-action="click->show-actions#addSection">
            <i class="fa-light fa-folder-plus"></i>
            Add Section
          </button>
          <button class="show-action-btn show-action-btn-primary" data-action="click->show-actions#addItem">
            <i class="fa-light fa-plus"></i>
            Add Item
          </button>
        <% end %>
        <button class="show-action-btn" data-action="click->collaboration#toggle" aria-label="Collaboration">
          <i class="fa-light fa-users"></i>
          Share
        </button>
        <% if list_owner? %>
          <button class="show-action-btn show-action-btn-danger" onclick="document.getElementById('delete-dialog-<%= @todo_list.id %>').classList.add('delete-modal--open')" aria-label="Delete list">
            <i class="fa-light fa-trash"></i>
          </button>
        <% end %>
      </div>
    </div>

    <% if flash.any? %>
      <div class="show-flash">
        <%= render "shared/flash_messages" %>
      </div>
    <% end %>

    <% has_content = @unsectioned_items.present? || @sections.any? %>

    <div class="empty-list-slate" data-show-actions-target="emptySlate" <% if has_content %>style="display: none;"<% end %>>
      <div class="empty-list-illustration">
        <i class="fa-light fa-party-horn"></i>
      </div>
      <h2>Your list is ready! ✏️</h2>
      <p>"<%= @todo_list.name %>" has been created. Start adding items and sections to bring it to life!</p>
      <div class="empty-list-actions">
        <button class="show-action-btn show-action-btn-primary" data-action="click->show-actions#addItem">
          <i class="fa-light fa-plus"></i>
          Add First Item
        </button>
        <button class="show-action-btn" data-action="click->show-actions#addSection">
          <i class="fa-light fa-folder-plus"></i>
          Add Section
        </button>
      </div>
    </div>

    <div class="show-content" id="show-content" data-controller="drag-reorder" data-drag-reorder-url-value="<%= reorder_todo_list_todo_items_path(@todo_list) %>" data-show-actions-target="content" <% unless has_content %>style="display: none;"<% end %>>
      <div class="unsectioned-items" id="unsectioned-items">
        <div class="unsectioned-header">
          <span>Items without section</span>
        </div>
        <div id="unsectioned-item-list">
          <% @unsectioned_items.each do |item| %>
            <% if item.completed? %>
              <%= render "todo_lists/todo_item_completed", item: item, todo_list: @todo_list %>
            <% else %>
              <%= render "todo_lists/todo_item", item: item, todo_list: @todo_list %>
            <% end %>
          <% end %>
        </div>
      </div>

      <% @sections.each do |section| %>
        <%= render "todo_lists/section", section: section, todo_list: @todo_list %>
      <% end %>
    </div>

    <template data-show-actions-target="itemTemplate">
      <%= render "todo_lists/inline_item_input", todo_list: @todo_list %>
    </template>
    <template data-show-actions-target="sectionTemplate">
      <%= render "todo_lists/inline_section_input", todo_list: @todo_list %>
    </template>

    <% if list_owner? %>
      <%= render "delete_confirmation", todo_list: @todo_list %>
    <% end %>

    <%= render "todo_lists/collaboration_panel",
      todo_list: @todo_list,
      collaborators: @todo_list.list_collaborators.includes(:user),
      pending_invitations: @todo_list.list_invitations.active %>
  </div>
</div>
