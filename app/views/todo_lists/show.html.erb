<div class="show-layout">
  <%= render "sidebar", sidebar_lists: @sidebar_lists, current_list: @todo_list %>

  <div class="show-main">
    <div class="show-header">
      <div class="show-header-left">
        <%= link_to todo_lists_path, class: "show-back-btn", aria: { label: "Back to lists" } do %>
          <wa-icon name="arrow-left" variant="thin"></wa-icon>
        <% end %>
        <div class="show-title-group">
          <% if @todo_list.icon.present? %>
            <wa-icon name="<%= @todo_list.icon %>" variant="thin" class="show-title-icon" style="color: var(--list-color-<%= @todo_list.color %>);"></wa-icon>
          <% end %>
          <h1 class="show-title"><%= @todo_list.name %></h1>
          <%= link_to edit_todo_list_path(@todo_list), class: "show-edit-btn", aria: { label: "Edit list" } do %>
            <wa-icon name="pen" variant="thin"></wa-icon>
          <% end %>
        </div>
      </div>

      <div class="show-header-right">
        <button class="show-action-btn show-action-btn-section" id="add-section-trigger">
          <wa-icon name="folder-plus" variant="thin"></wa-icon>
          Add Section
        </button>
        <button class="show-action-btn show-action-btn-primary" id="add-item-trigger">
          <wa-icon name="plus" variant="thin"></wa-icon>
          Add Item
        </button>
      </div>
    </div>

    <% if flash.any? %>
      <div class="show-flash">
        <%= render "shared/flash_messages" %>
      </div>
    <% end %>

    <% has_content = @unsectioned_items.present? || @sections.any? %>

    <% unless has_content %>
      <div class="empty-list-slate">
        <div class="empty-list-illustration">
          <wa-icon name="party-horn" variant="thin"></wa-icon>
        </div>
        <h2>Your list is ready!</h2>
        <p>"<%= @todo_list.name %>" has been created. Start adding items and sections to bring it to life!</p>
        <div class="empty-list-actions">
          <button class="show-action-btn show-action-btn-primary" id="add-first-item-trigger">
            <wa-icon name="plus" variant="thin"></wa-icon>
            Add First Item
          </button>
          <button class="show-action-btn" id="add-first-section-trigger">
            <wa-icon name="folder-plus" variant="thin"></wa-icon>
            Add Section
          </button>
        </div>
      </div>
    <% else %>
      <div class="show-content" id="show-content" data-controller="drag-reorder" data-drag-reorder-url-value="<%= reorder_todo_list_todo_items_path(@todo_list) %>">
        <% if @unsectioned_items.present? %>
          <div class="unsectioned-items" id="unsectioned-items">
            <div class="unsectioned-header">
              <span>Items without section</span>
            </div>
            <% @unsectioned_items.each do |item| %>
              <% if item.completed? %>
                <%= render "todo_lists/todo_item_completed", item: item, todo_list: @todo_list %>
              <% else %>
                <%= render "todo_lists/todo_item", item: item, todo_list: @todo_list %>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <% @sections.each do |section| %>
          <%= render "todo_lists/section", section: section, todo_list: @todo_list %>
        <% end %>
      </div>
    <% end %>

    <%= render "delete_confirmation", todo_list: @todo_list %>
  </div>
</div>
