<div data-controller="context-menu"
  data-context-menu-section-id-value="<%= section.id %>"
  data-context-menu-list-id-value="<%= todo_list.id %>">
  <wa-dropdown placement="bottom-end" data-action="wa-select->context-menu#dispatch">
    <wa-button slot="trigger" size="small" appearance="plain" class="section-more">
      <wa-icon name="ellipsis-vertical" variant="thin"></wa-icon>
    </wa-button>
    <wa-dropdown-item value="edit">Edit</wa-dropdown-item>
    <wa-dropdown-item value="move">Move...</wa-dropdown-item>
    <wa-dropdown-item value="copy">Copy...</wa-dropdown-item>
    <wa-divider></wa-divider>
    <wa-dropdown-item value="new_list">New list from group</wa-dropdown-item>
    <wa-divider></wa-divider>
    <wa-dropdown-item value="archive">Archive group</wa-dropdown-item>
    <wa-dropdown-item value="delete" variant="danger">Delete group</wa-dropdown-item>
    <wa-divider></wa-divider>
    <wa-dropdown-item value="insert">Insert a to-do</wa-dropdown-item>
  </wa-dropdown>
  <div hidden>
    <%= button_to archive_todo_list_todo_section_path(todo_list, section), method: :patch, data: { context_menu_target: "archiveForm" } %>
    <%= button_to todo_list_todo_section_path(todo_list, section), method: :delete, data: { context_menu_target: "deleteForm", turbo_confirm: "Are you sure you want to delete this section and all its items?" } %>
  </div>
</div>
