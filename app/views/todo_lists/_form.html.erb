<div class="form-fields">
  <%# List Name %>
  <div class="form-field<%= ' form-field-error' if todo_list.errors[:name].any? %>">
    <label class="form-label" for="todo_list_name">List Name</label>
    <wa-input id="todo_list_name" name="todo_list[name]" value="<%= todo_list.name %>" placeholder="e.g., Weekend Project, Grocery Run..." size="medium" pill></wa-input>
    <% if todo_list.errors[:name].any? %>
      <div class="form-error-text">
        <wa-icon name="circle-exclamation" variant="thin"></wa-icon>
        <%= todo_list.errors[:name].first %>
      </div>
    <% end %>
  </div>

  <%# Icon & Color Row %>
  <div class="form-icon-color-row">
    <div class="form-icon-section">
      <label class="form-label">Icon</label>
      <div class="icon-picker" data-controller="icon-picker">
        <input type="hidden" name="todo_list[icon]" value="<%= todo_list.icon %>" data-icon-picker-target="input">
        <% TodoList::ICONS.first(5).each do |icon_name| %>
          <wa-button
            size="medium"
            appearance="outlined"
            variant="neutral"
            class="icon-picker-btn <%= 'active' if todo_list.icon == icon_name %>"
            data-action="click->icon-picker#select"
            data-icon="<%= icon_name %>">
            <wa-icon name="<%= icon_name %>" variant="thin" label="<%= icon_name.humanize %>"></wa-icon>
          </wa-button>
        <% end %>
        <wa-button
          size="medium"
          appearance="outlined"
          variant="neutral"
          class="icon-picker-btn"
          data-action="click->icon-picker#toggle">
          <wa-icon name="plus" variant="thin" label="More icons"></wa-icon>
        </wa-button>
      </div>
    </div>

    <div class="form-color-section">
      <label class="form-label">Color</label>
      <div class="color-picker" data-controller="color-picker">
        <input type="hidden" name="todo_list[color]" value="<%= todo_list.color || TodoList::COLORS.first %>" data-color-picker-target="input">
        <% TodoList::COLORS.each do |color| %>
          <button type="button"
            class="color-swatch <%= 'active' if (todo_list.color || TodoList::COLORS.first) == color %>"
            data-action="click->color-picker#select"
            data-color="<%= color %>"
            aria-label="<%= color.capitalize %> color">
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <%# Description %>
  <div>
    <div class="form-label-row">
      <label class="form-label">Description</label>
      <span class="form-label-optional">(optional)</span>
    </div>
    <textarea name="todo_list[description]" class="form-textarea" placeholder="What's this list about? Add a quick description..." maxlength="500"><%= todo_list.description %></textarea>
  </div>

  <%# Template Picker %>
  <div>
    <label class="form-label">Start with a template</label>
    <div class="template-picker" data-controller="template-picker">
      <input type="hidden" name="todo_list[template]" value="<%= todo_list.template || 'blank' %>" data-template-picker-target="input">
      <% { blank: "wand-magic-sparkles", project: "table-columns", weekly: "calendar-week", shopping: "cart-shopping" }.each do |tmpl, icon| %>
        <wa-button
          variant="neutral"
          appearance="outlined"
          size="small"
          class="template-card <%= 'active' if (todo_list.template || 'blank') == tmpl.to_s %> <%= 'disabled' if local_assigns[:editing] %>"
          data-action="click->template-picker#select"
          data-template="<%= tmpl %>"
          <%= 'disabled' if local_assigns[:editing] %>>
          <wa-icon slot="start" name="<%= icon %>" variant="thin"></wa-icon>
          <%= tmpl.to_s.capitalize %>
        </wa-button>
      <% end %>
    </div>
  </div>
</div>
