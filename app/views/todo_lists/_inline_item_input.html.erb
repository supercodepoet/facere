<div class="inline-item-wrapper" id="inline-item-wrapper" data-controller="inline-item">
  <%= form_with(model: [todo_list, TodoItem.new], url: todo_list_todo_items_path(todo_list), id: "inline-item-input",
       class: "active-input-row",
       data: { action: "turbo:submit-end->inline-item#afterSubmit" }) do |f| %>
    <%= f.hidden_field :todo_section_id, value: local_assigns[:section]&.id %>
    <div class="todo-item-check-circle"></div>
    <%= f.text_field :name, class: "inline-item-text", placeholder: "What needs to be done?",
        data: { inline_item_target: "input", action: "keydown->inline-item#handleKeydown" },
        autofocus: true %>
    <div class="input-hints">
      <span class="input-hint-badge">Enter</span>
      <span class="input-hint-text">to save</span>
      <span class="input-hint-badge">Esc</span>
      <span class="input-hint-text">to cancel</span>
    </div>
  <% end %>
  <div class="quick-actions-bar">
    <button class="quick-action-btn" type="button">
      <i class="fa-light fa-user-plus"></i>
      Assign
    </button>
    <button class="quick-action-btn" type="button">
      <i class="fa-light fa-calendar"></i>
      Due date
    </button>
    <button class="quick-action-btn" type="button">
      <i class="fa-light fa-flag"></i>
      Priority
    </button>
  </div>
  <div class="inline-divider"></div>
  <div class="inline-empty-hint" data-inline-item-target="emptyHint">
    <span class="inline-empty-hint-emoji">✍️</span>
    <span class="inline-empty-hint-title">Start typing to add your first item</span>
    <span class="inline-empty-hint-subtext">Pro tip: Hit Enter to save and immediately start typing the next one!</span>
  </div>
</div>
