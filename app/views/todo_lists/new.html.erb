<div class="form-page">
  <div class="form-card">
    <% if flash[:alert] %>
      <div class="form-error-banner">
        <i class="fa-light fa-triangle-exclamation form-error-banner-icon"></i>
        <span class="form-error-banner-text"><%= flash[:alert] %></span>
        <button class="form-error-banner-close" onclick="this.closest('.form-error-banner').remove()">
          <i class="fa-light fa-xmark" aria-label="Dismiss"></i>
        </button>
      </div>
    <% end %>

    <div class="form-card-header">
      <i class="fa-light fa-clipboard-list"></i>
      <h1>Create a new list</h1>
      <p>Give your list a name, pick an icon, and get organized!</p>
    </div>

    <%= form_with(model: @todo_list) do |form| %>
      <%= render "form", todo_list: @todo_list, form: form %>

      <div class="form-actions">
        <a class="form-cancel-btn" href="<%= todo_lists_path %>">Cancel</a>
        <button type="submit" class="form-submit-btn">
          Create List
        </button>
      </div>
    <% end %>
  </div>
</div>
