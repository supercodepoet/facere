<div class="active-section-input" id="inline-section-input"
     data-controller="inline-section"
     data-inline-section-list-id-value="<%= todo_list.id %>">
  <div class="section-icon-picker">
    <wa-icon name="folder" variant="thin" data-inline-section-target="iconDisplay"></wa-icon>
    <wa-icon name="chevron-down" variant="thin" class="icon-picker-chevron"></wa-icon>
  </div>
  <input type="text" class="inline-section-text" placeholder="Section name..."
         data-inline-section-target="input"
         data-action="keydown->inline-section#handleKeydown"
         autofocus>
  <input type="hidden" data-inline-section-target="iconInput" value="">
  <div class="input-hints">
    <span class="input-hint-badge">Enter</span>
    <span class="input-hint-text">to create</span>
  </div>
</div>
