<div class="form-page">
  <div class="form-card">
    <% if flash[:alert] %>
      <div class="form-error-banner">
        <i class="fa-light fa-triangle-exclamation form-error-banner-icon"></i>
        <span class="form-error-banner-text"><%= flash[:alert] %></span>
        <button class="form-error-banner-close" onclick="this.closest('.form-error-banner').remove()">
          <i class="fa-light fa-xmark" aria-label="Dismiss"></i>
        </button>
      </div>
    <% end %>

    <div class="form-card-header">
      <i class="fa-light fa-pen-to-square"></i>
      <h1>Edit list</h1>
      <p>Update your list's name, icon, color, and description</p>
    </div>

    <%= form_with(model: @todo_list) do |form| %>
      <%= render "form", todo_list: @todo_list, form: form, editing: true %>

      <div class="form-actions">
        <a class="form-cancel-btn" href="<%= todo_list_path(@todo_list) %>">Cancel</a>
        <button type="submit" class="form-submit-btn">
          Save Changes
        </button>
      </div>
    <% end %>
  </div>
</div>
