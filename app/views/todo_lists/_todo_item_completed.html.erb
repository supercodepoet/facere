<%= turbo_frame_tag dom_id(item) do %>
  <div class="todo-item todo-item--completed" id="<%= dom_id(item) %>" draggable="true"
       data-controller="item-checkbox"
       data-item-checkbox-url-value="<%= toggle_todo_list_todo_item_path(todo_list, item) %>">
    <wa-icon name="grip-dots-vertical" variant="thin" class="drag-handle"></wa-icon>
    <button class="todo-item-checkbox todo-item-checkbox--done" data-action="click->item-checkbox#toggle">
      <div class="todo-item-check-done">
        <wa-icon name="check" variant="solid" class="todo-item-check-icon"></wa-icon>
      </div>
    </button>
    <span class="todo-item-title todo-item-title--done"><%= item.name %></span>
  </div>
<% end %>
