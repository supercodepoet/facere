<div class="auth-social-buttons" role="group" aria-label="Sign in with third-party providers">
  <%= form_tag "/auth/google_oauth2", method: :post, data: { turbo: false, controller: "oauth" } do %>
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <button class="auth-social-btn" type="submit" data-oauth-target="button" data-action="click->oauth#loading" aria-label="Sign in with Google">
      <i class="fa-brands fa-google"></i>
      Google
    </button>
  <% end %>

  <%= form_tag "/auth/apple", method: :post, data: { turbo: false, controller: "oauth" } do %>
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <button class="auth-social-btn" type="submit" data-oauth-target="button" data-action="click->oauth#loading" aria-label="Sign in with Apple">
      <i class="fa-brands fa-apple"></i>
      Apple
    </button>
  <% end %>
</div>
