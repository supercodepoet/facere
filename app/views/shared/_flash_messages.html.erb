<div aria-live="polite" aria-atomic="true" class="flash-container">
<% flash.each do |type, message| %>
  <%
    variant = case type.to_s
              when "notice", "success" then "success"
              when "alert", "error"   then "danger"
              when "warning"          then "warning"
              else "primary"
              end
    icon = case variant
           when "success" then "circle-check"
           when "danger"  then "circle-exclamation"
           else "triangle-exclamation"
           end
  %>
  <div class="flash-toast flash-toast-<%= variant %>" role="alert" data-controller="flash-toast" data-flash-toast-duration-value="8000">
    <wa-icon name="<%= icon %>" variant="solid" class="flash-toast-icon"></wa-icon>
    <span class="flash-toast-message"><%= message %></span>
    <button type="button" class="flash-toast-close" data-action="flash-toast#dismiss" aria-label="Dismiss">
      <wa-icon name="xmark" variant="thin"></wa-icon>
    </button>
  </div>
<% end %>
</div>
