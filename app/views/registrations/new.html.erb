<%= turbo_frame_tag "auth_form" do %>
<div class="auth-form-container auth-form-signup" data-controller="form-validation">
  <h1 class="auth-form-title" style="text-align: center;">Create your account</h1>
  <p class="auth-form-subtitle">Start your productivity journey today</p>

  <div class="auth-segmented-control">
    <%= link_to "Sign In", sign_in_path, data: { turbo_frame: "auth_form" } %>
    <%= link_to "Sign Up", sign_up_path, class: "active", data: { turbo_frame: "auth_form" } %>
  </div>

  <%= form_with model: @user, url: sign_up_path, data: { action: "submit->form-validation#validateForm", turbo_frame: "_top" } do |f| %>
    <div class="auth-fields">
      <div class="auth-field">
        <label class="auth-field-label">Name</label>
        <div class="auth-input-wrap">
          <i class="fa-light fa-user" style="color: var(--color-zinc-400);"></i>
          <input type="text" name="user[name]" value="<%= @user.name %>" required data-form-validation-target="name" data-action="input->form-validation#clearError" class="auth-input" />
        </div>
      </div>

      <div class="auth-field">
        <label class="auth-field-label">Email address</label>
        <div class="auth-input-wrap">
          <i class="fa-light fa-envelope" style="color: var(--color-zinc-400);"></i>
          <input type="email" name="user[email_address]" value="<%= @user.email_address %>" required data-form-validation-target="email" data-action="input->form-validation#validateEmail" class="auth-input" />
        </div>
      </div>

      <div class="auth-field" data-controller="password-visibility">
        <label class="auth-field-label">Password</label>
        <div class="auth-input-wrap">
          <i class="fa-light fa-lock" style="color: var(--color-zinc-400);"></i>
          <input type="password" name="user[password]" required minlength="8" data-form-validation-target="password" data-password-visibility-target="input" data-action="input->form-validation#validatePassword" class="auth-input" />
          <i
            class="fa-light fa-eye-slash"
            data-action="click->password-visibility#toggle"
            data-password-visibility-target="toggle"
            style="color: var(--color-zinc-400); cursor: pointer; padding: 4px;"
            role="button"
            tabindex="0"
            aria-label="Toggle password visibility"
          ></i>
        </div>
      </div>

      <div class="auth-field" data-controller="password-visibility">
        <label class="auth-field-label">Confirm Password</label>
        <div class="auth-input-wrap">
          <i class="fa-light fa-lock" style="color: var(--color-zinc-400);"></i>
          <input type="password" name="user[password_confirmation]" required data-form-validation-target="passwordConfirmation" data-password-visibility-target="input" data-action="input->form-validation#validatePasswordConfirmation" class="auth-input" />
          <i
            class="fa-light fa-eye-slash"
            data-action="click->password-visibility#toggle"
            data-password-visibility-target="toggle"
            style="color: var(--color-zinc-400); cursor: pointer; padding: 4px;"
            role="button"
            tabindex="0"
            aria-label="Toggle password visibility"
          ></i>
        </div>
      </div>

    </div>

    <div class="auth-checkbox-row">
      <label class="auth-checkbox-label">
        <input type="checkbox" name="user[terms_accepted]" value="1" required data-form-validation-target="terms" class="auth-checkbox" />
        I agree to the <a href="#" target="_blank">Terms of Service</a> and <a href="#" target="_blank">Privacy Policy</a>
      </label>
    </div>

    <% if @user.errors.any? %>
      <div class="auth-callout auth-callout--danger">
        <i class="fa-light fa-circle-exclamation"></i>
        <% @user.errors.full_messages.each do |msg| %>
          <div><%= msg %></div>
        <% end %>
      </div>
    <% end %>

    <button
      class="auth-primary-btn"
      type="submit"
      data-turbo-submits-with="Creating account..."
    >
      Create Account
    </button>
  <% end %>

  <div class="auth-divider">
    <div class="auth-divider-line"></div>
    <span class="auth-divider-text">or</span>
    <div class="auth-divider-line"></div>
  </div>

  <%= render "shared/oauth_buttons" %>

  <div class="auth-prompt">
    <span>Already have an account?</span>
    <%= link_to "Sign In", sign_in_path, data: { turbo_frame: "auth_form" } %>
  </div>
</div>
<% end %>
