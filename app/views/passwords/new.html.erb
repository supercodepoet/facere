<div class="auth-form-container">
  <h1 class="auth-form-title" style="text-align: center;">Reset your password</h1>
  <p class="auth-form-subtitle">Enter your email and we'll send you a reset link</p>

  <%= form_with url: passwords_path do |f| %>
    <div class="auth-fields">
      <div class="auth-field">
        <wa-input
          label="Email"
          name="email_address"
          type="email"
          required
          autofocus
          autocomplete="username"
        >
          <wa-icon slot="start" name="envelope" variant="thin" style="color: var(--color-zinc-400);"></wa-icon>
        </wa-input>
      </div>
    </div>

    <wa-button
      variant="brand"
      class="auth-primary-btn"
      type="submit"
      data-turbo-submits-with="Sending..."
    >
      Send Reset Link
    </wa-button>
  <% end %>

  <div class="auth-prompt" style="margin-top: 24px;">
    <%= link_to sign_in_path, style: "color: var(--color-primary); font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;" do %>
      <wa-icon name="arrow-left" variant="thin" style="font-size: 14px;"></wa-icon>
      Back to Sign In
    <% end %>
  </div>
</div>
