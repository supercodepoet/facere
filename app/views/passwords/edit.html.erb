<div class="auth-form-container" data-controller="form-validation">
  <h1 class="auth-form-title" style="text-align: center;">Set new password</h1>
  <p class="auth-form-subtitle">Choose a strong password for your account</p>

  <%= form_with url: password_path(params[:token]), method: :patch do |f| %>
    <div class="auth-fields">
      <div class="auth-field" data-controller="password-visibility">
        <label class="auth-field-label">New Password</label>
        <div class="auth-input-wrap">
          <i class="fa-light fa-lock" style="color: var(--color-zinc-400);"></i>
          <input type="password" name="password" required minlength="8" autocomplete="new-password" maxlength="72" data-form-validation-target="password" data-password-visibility-target="input" data-action="input->form-validation#validatePassword" class="auth-input" />
          <i
            class="fa-light fa-eye-slash"
            data-action="click->password-visibility#toggle"
            data-password-visibility-target="toggle"
            style="color: var(--color-zinc-400); cursor: pointer; padding: 4px;"
            role="button"
            tabindex="0"
            aria-label="Toggle password visibility"
          ></i>
        </div>
        <div class="password-requirements" data-form-validation-target="requirements">
          <small data-req="length">At least 8 characters</small>
          <small data-req="uppercase">One uppercase letter</small>
          <small data-req="lowercase">One lowercase letter</small>
          <small data-req="digit">One number</small>
          <small data-req="special">One special character</small>
        </div>
      </div>

      <div class="auth-field" data-controller="password-visibility">
        <label class="auth-field-label">Confirm Password</label>
        <div class="auth-input-wrap">
          <i class="fa-light fa-lock" style="color: var(--color-zinc-400);"></i>
          <input type="password" name="password_confirmation" required autocomplete="new-password" maxlength="72" data-form-validation-target="passwordConfirmation" data-password-visibility-target="input" data-action="input->form-validation#validatePasswordConfirmation" class="auth-input" />
          <i
            class="fa-light fa-eye-slash"
            data-action="click->password-visibility#toggle"
            data-password-visibility-target="toggle"
            style="color: var(--color-zinc-400); cursor: pointer; padding: 4px;"
            role="button"
            tabindex="0"
            aria-label="Toggle password visibility"
          ></i>
        </div>
      </div>
    </div>

    <button
      class="auth-primary-btn"
      type="submit"
      data-turbo-submits-with="Updating..."
    >
      Update Password
    </button>
  <% end %>
</div>
