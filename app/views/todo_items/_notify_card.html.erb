<div class="detail-card">
  <div class="detail-card-header">
    <span class="detail-card-label">Notify on Complete</span>
    <span class="detail-card-spacer"></span>
    <%= button_to todo_list_todo_item_notify_people_path(todo_list, item), params: { notify_person: { user_id: Current.user.id } }, class: "detail-card-icon-btn" do %>
      <wa-icon name="bell-plus" style="color: #8B5CF6;"></wa-icon>
    <% end %>
  </div>
  <% if item.notify_people.any? %>
    <div class="notify-list">
      <% item.notify_people.includes(:user).each do |np| %>
        <div class="notify-person-row">
          <div class="assignee-avatar" style="background: #6366F1;">
            <%= np.user.initials %>
          </div>
          <span class="assignee-name"><%= np.user.name %></span>
          <%= button_to todo_list_todo_item_notify_person_path(todo_list, item, np), method: :delete, class: "detail-card-icon-btn" do %>
            <wa-icon name="xmark" style="color: #A1A1AA;"></wa-icon>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <span class="detail-card-empty">No notifications set</span>
  <% end %>
</div>
