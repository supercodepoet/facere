<div class="detail-section" data-controller="notes-edit">
  <div class="detail-section-header">
    <i class="fa-light fa-file-lines detail-section-icon" style="color: #8B5CF6;"></i>
    <span class="detail-section-title">Notes</span>
    <div class="detail-section-spacer"></div>
    <button type="button" class="notes-edit-btn" data-notes-edit-target="editBtn" data-action="click->notes-edit#enterEdit">
      <i class="fa-light fa-pen" style="font-size: 14px;"></i>
      Edit
    </button>
  </div>

  <%# View mode: show content or placeholder %>
  <div data-notes-edit-target="view">
    <% if item.notes.present? %>
      <div class="notes-content-card">
        <div class="notes-content lexxy-content"><%= item.notes %></div>
      </div>
    <% else %>
      <div class="notes-content-card">
        <span class="notes-placeholder">No notes yet</span>
      </div>
    <% end %>
  </div>

  <%# Edit mode: Lexxy editor (hidden by default) %>
  <div data-notes-edit-target="editor" style="display: none;" data-controller="notes-autosave">
    <%= form_with model: [todo_list, item], url: todo_list_todo_item_path(todo_list, item), method: :patch, data: { notes_autosave_target: "form" } do |f| %>
      <div class="notes-editor-wrap">
        <%= f.rich_text_area :notes, class: "lexxy-editor", data: { action: "input->notes-autosave#changed" } %>
        <div class="notes-bottom-row">
          <div class="notes-bottom-spacer"></div>
          <div class="notes-bottom-actions">
            <button type="button" class="notes-cancel-btn" data-action="click->notes-edit#cancel">Cancel</button>
            <button type="button" class="notes-save-btn" data-action="click->notes-edit#save">Save</button>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
