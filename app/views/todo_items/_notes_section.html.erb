<div class="detail-section" data-controller="notes-autosave">
  <div class="detail-section-header">
    <wa-icon name="file-lines" variant="thin" class="detail-section-icon" style="color: #8B5CF6;"></wa-icon>
    <span class="detail-section-title">Notes</span>
  </div>
  <div class="notes-editor-card">
    <%= form_with(model: item, url: todo_list_todo_item_path(todo_list, item), method: :patch, data: { notes_autosave_target: "form" }) do |f| %>
      <%= f.rich_text_area :notes, class: "notes-lexxy-editor", data: { action: "lexxy:change->notes-autosave#changed" } %>
    <% end %>
  </div>
</div>
