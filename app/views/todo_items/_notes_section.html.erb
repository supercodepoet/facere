<div class="detail-section" data-controller="notes-editor">
  <div class="detail-section-header">
    <wa-icon name="file-lines" variant="thin" class="detail-section-icon"></wa-icon>
    <span class="detail-section-title">Notes</span>
    <div class="detail-section-spacer"></div>
    <button class="detail-section-edit-btn" data-action="click->notes-editor#toggleEdit" data-notes-editor-target="editBtn">
      <wa-icon name="pen" variant="thin"></wa-icon>
    </button>
  </div>
  <div class="detail-section-body" data-notes-editor-target="viewMode">
    <% if item.notes.present? %>
      <div class="notes-content"><%= item.notes %></div>
    <% else %>
      <p class="notes-placeholder">Click the edit button to add notes...</p>
    <% end %>
  </div>
  <div class="notes-edit-form" data-notes-editor-target="editMode" style="display: none;">
    <%= form_with(model: item, url: todo_list_todo_item_path(item.todo_list, item), method: :patch, data: { notes_editor_target: "form" }) do |f| %>
      <%= f.rich_text_area :notes, class: "notes-trix-editor" %>
      <div class="notes-form-actions">
        <button type="submit" class="notes-save-btn">Save Notes</button>
        <button type="button" class="notes-cancel-btn" data-action="click->notes-editor#cancelEdit">Cancel</button>
      </div>
    <% end %>
  </div>
</div>
