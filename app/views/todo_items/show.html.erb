<div class="show-layout">
  <%= render "todo_lists/sidebar", sidebar_lists: @sidebar_lists, current_list: @todo_list %>

  <div class="show-main">
    <div class="show-header">
      <div class="show-header-left">
        <%= link_to todo_list_path(@todo_list), class: "show-back-btn", aria: { label: "Back to list" } do %>
          <i class="fa-light fa-arrow-left"></i>
        <% end %>
        <div class="show-title-group">
          <div class="show-list-icon" style="background: #8B5CF6;">
            <i class="fa-solid fa-list-check" style="color: #FFFFFF; font-size: 18px;"></i>
          </div>
          <h1 class="show-title"><%= @todo_list.name %></h1>
          <%= link_to edit_todo_list_path(@todo_list), class: "show-edit-btn", aria: { label: "Edit list" } do %>
            <i class="fa-light fa-pen" style="font-size: 14px;"></i>
          <% end %>
        </div>
      </div>
      <div class="show-header-right">
        <%= button_to toggle_todo_list_todo_item_path(@todo_list, @todo_item), method: :patch, class: "item-topbar-btn item-topbar-btn--complete #{'item-topbar-btn--completed' if @todo_item.completed?}", data: { turbo: false } do %>
          <i class="fa-solid fa-circle-check"></i>
          <%= @todo_item.completed? ? "Completed" : "Mark Complete" %>
        <% end %>
        <button type="button" class="item-topbar-btn item-topbar-btn--delete" onclick="document.getElementById('delete-item-dialog').classList.add('delete-modal--open')">
          <i class="fa-light fa-trash-can"></i>
          Delete
        </button>
      </div>
    </div>

    <div id="delete-item-dialog" class="delete-modal-overlay" data-controller="modal" data-action="click->modal#backdropClose">
      <div class="delete-modal-panel" data-action="click->modal#stopPropagation">
        <div class="delete-modal-content">
          <div class="delete-modal-icon">
            <i class="fa-light fa-trash"></i>
          </div>
          <h2>Delete this item?</h2>
          <p>This will permanently delete "<%= @todo_item.name %>". You won't be able to undo this action.</p>
          <div class="delete-modal-actions">
            <button class="delete-cancel-btn" data-action="click->modal#close">Cancel</button>
            <%= button_to todo_list_todo_item_path(@todo_list, @todo_item), method: :delete, class: "delete-confirm-btn", data: { turbo: false } do %>
              <i class="fa-light fa-trash"></i>
              Delete
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="item-detail-content">
      <div class="item-detail-left">
        <%# Item Header %>
        <div class="item-header" id="item_header_<%= @todo_item.id %>">
          <div class="item-status-row">
            <span class="item-badge" style="background: #8B5CF620; color: #8B5CF6;">
              <span class="item-badge-dot" style="background: #8B5CF6;"></span>
              <%= @todo_item.status_label %>
            </span>
            <% if @todo_item.priority != "none" %>
              <span class="item-badge" style="background: <%= @todo_item.priority_bg_color %>; color: <%= @todo_item.priority_color %>;">
                <i class="fa-solid fa-flag" style="font-size: 12px;"></i>
                <%= @todo_item.priority_label %> Priority
              </span>
            <% end %>
          </div>
          <%# Issue 14: Editable item name %>
          <div data-controller="inline-edit">
            <h2 class="item-detail-title" data-inline-edit-target="display" data-action="click->inline-edit#edit"><%= @todo_item.name %></h2>
            <%= form_with(model: @todo_item, url: todo_list_todo_item_path(@todo_list, @todo_item), method: :patch, class: "inline-edit-form", data: { inline_edit_target: "form", turbo: false }) do |f| %>
              <%= f.text_field :name, value: @todo_item.name, class: "item-title-input", data: { inline_edit_target: "input", action: "keydown.enter->inline-edit#save keydown.esc->inline-edit#cancel" } %>
            <% end %>
          </div>
          <div class="item-meta-row">
            <span class="item-meta">
              <i class="fa-light fa-calendar"></i>
              Created <%= @todo_item.created_at.strftime("%b %-d, %Y") %>
            </span>
            <% if @todo_item.todo_section.present? %>
              <span class="item-meta">
                <i class="fa-light fa-folder"></i>
                <%= @todo_item.todo_section.name %>
              </span>
            <% end %>
          </div>
        </div>

        <div class="item-divider"></div>

        <turbo-frame id="item_notes_<%= @todo_item.id %>">
          <%= render "todo_items/notes_section", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <div class="item-divider"></div>

        <turbo-frame id="item_checklist_<%= @todo_item.id %>">
          <%= render "todo_items/checklist_section", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <div class="item-divider"></div>

        <turbo-frame id="item_attachments_<%= @todo_item.id %>">
          <%= render "todo_items/attachments_section", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <div class="item-divider"></div>

        <%= render "todo_items/comments_section", item: @todo_item, todo_list: @todo_list %>
      </div>

      <div class="item-detail-right">
        <turbo-frame id="item_status_<%= @todo_item.id %>">
          <%= render "todo_items/status_sidebar", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <turbo-frame id="item_priority_<%= @todo_item.id %>">
          <%= render "todo_items/priority_card", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <turbo-frame id="item_assignees_<%= @todo_item.id %>">
          <%= render "todo_items/assignees_card", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <turbo-frame id="item_due_date_<%= @todo_item.id %>">
          <%= render "todo_items/due_date_card", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <turbo-frame id="item_notify_<%= @todo_item.id %>">
          <%= render "todo_items/notify_card", item: @todo_item, todo_list: @todo_list %>
        </turbo-frame>

        <div class="detail-card tags-card-wrap" data-controller="tag-editor">
          <turbo-frame id="item_tags_<%= @todo_item.id %>">
            <%= render "todo_items/tags_card", item: @todo_item, todo_list: @todo_list %>
          </turbo-frame>

          <button type="button" class="tags-card-trigger" data-action="click->tag-editor#toggleEditor">
            <i class="fa-light fa-plus"></i>
            Manage tags
          </button>

          <turbo-frame id="tag_editor_<%= @todo_item.id %>" data-tag-editor-target="editorFrame" data-src="<%= todo_list_todo_item_tags_path(@todo_list, @todo_item) %>">
          </turbo-frame>
        </div>

      </div>
    </div>
  </div>
</div>
