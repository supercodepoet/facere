<div class="detail-section">
  <div class="detail-section-header">
    <wa-icon name="message-lines" variant="thin" class="detail-section-icon"></wa-icon>
    <span class="detail-section-title">Comments</span>
    <% if item.comments.any? %>
      <span class="comments-count-badge"><%= item.comments.size %></span>
    <% end %>
  </div>
  <div class="comments-list">
    <% item.comments.includes(:user).each do |comment| %>
      <div class="comment-row">
        <div class="comment-avatar" style="background: var(--list-color-<%= todo_list.color %>);">
          <%= comment.user.initials %>
        </div>
        <div class="comment-body">
          <div class="comment-header">
            <span class="comment-author"><%= comment.user.name %></span>
            <span class="comment-time"><%= time_ago_in_words(comment.created_at) %> ago</span>
          </div>
          <p class="comment-text"><%= comment.body %></p>
        </div>
      </div>
    <% end %>
  </div>
  <%= form_with(url: todo_list_todo_item_comments_path(todo_list, item), method: :post, class: "comment-input-row") do |f| %>
    <div class="comment-avatar comment-avatar--self" style="background: var(--list-color-<%= todo_list.color %>);">
      <%= Current.user.initials %>
    </div>
    <%= f.text_field :body, placeholder: "Write a comment...", class: "comment-input-field", name: "comment[body]" %>
    <%= f.submit "Send", class: "comment-send-btn" %>
  <% end %>
</div>
