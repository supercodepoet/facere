<div class="detail-card">
  <span class="detail-card-label">Status</span>
  <div class="status-selector">
    <% TodoItem::STATUSES.each do |status| %>
      <%= button_to status.humanize, todo_list_todo_item_path(todo_list, item), method: :patch, params: { todo_item: { status: status } }, class: "status-btn #{'status-btn--active' if item.status == status}" %>
    <% end %>
  </div>
</div>
