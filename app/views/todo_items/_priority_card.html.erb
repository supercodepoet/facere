<div class="detail-card">
  <div class="detail-card-header">
    <span class="detail-card-label" style="margin-bottom: 0;">PRIORITY</span>
  </div>
  <div class="priority-options">
    <% TodoItem::PRIORITIES.reverse.each do |p| %>
      <% selected = item.priority == p %>
      <%= button_to todo_list_todo_item_path(todo_list, item), method: :patch, params: { todo_item: { priority: p } }, class: "priority-option #{'priority-option--selected' if selected}", style: selected ? "--priority-selected-bg: #{TodoItem::PRIORITY_BG_COLORS[p]}" : nil, data: { turbo: false } do %>
        <span class="priority-dot" style="background: <%= TodoItem::PRIORITY_COLORS[p] %>;"></span>
        <span class="priority-text"><%= TodoItem::PRIORITY_LABELS[p] %></span>
        <% if selected %>
          <span style="margin-left: auto;"><i class="fa-solid fa-check" style="color: <%= TodoItem::PRIORITY_COLORS[p] %>;"></i></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</div>
