<div class="detail-card detail-card--actions">
  <%= button_to toggle_todo_list_todo_item_path(todo_list, item), method: :patch, class: "detail-action-btn detail-action-btn--complete #{'detail-action-btn--completed' if item.completed?}", data: { turbo: false } do %>
    <i class="fa-solid fa-circle-check"></i>
    <%= item.completed? ? "Completed" : "Mark Complete" %>
  <% end %>
  <%= button_to todo_list_todo_item_path(todo_list, item), method: :delete, class: "detail-action-btn detail-action-btn--delete", data: { turbo: false, turbo_confirm: "Are you sure you want to delete this item? This cannot be undone." } do %>
    <i class="fa-solid fa-trash"></i>
    Delete Item
  <% end %>
</div>
