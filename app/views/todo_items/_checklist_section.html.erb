<div class="detail-section" data-controller="checklist-add">
  <div class="detail-section-header">
    <i class="fa-light fa-list-check detail-section-icon" style="color: #8B5CF6;"></i>
    <span class="detail-section-title">Checklist</span>
    <% total = item.checklist_items.size %>
    <% done = item.checklist_items.count(&:completed?) %>
    <% if total > 0 %>
      <span class="checklist-progress-badge"><%= done %>/<%= total %></span>
    <% end %>
    <div class="detail-section-spacer"></div>
    <button type="button" class="detail-section-add-btn" data-action="click->checklist-add#show">
      <i class="fa-light fa-plus"></i>
      Add
    </button>
  </div>
  <div class="checklist-items">
    <% item.checklist_items.each do |check_item| %>
      <div class="checklist-row<%= ' checklist-row--done' if check_item.completed? %>" data-controller="inline-edit">
        <%= link_to toggle_todo_list_todo_item_checklist_item_path(todo_list, item, check_item), data: { turbo_method: :patch }, class: "checklist-toggle" do %>
          <% if check_item.completed? %>
            <div class="checklist-box checklist-box--checked">
              <i class="fa-solid fa-check" style="color: #FFFFFF; font-size: 12px;"></i>
            </div>
          <% else %>
            <div class="checklist-box"></div>
          <% end %>
        <% end %>
        <span class="checklist-text<%= ' checklist-text--done' if check_item.completed? %>" data-inline-edit-target="display" data-action="click->inline-edit#edit"><%= check_item.name %></span>
        <%= form_with(url: todo_list_todo_item_checklist_item_path(todo_list, item, check_item), method: :patch, class: "inline-edit-form checklist-edit-form", data: { inline_edit_target: "form", turbo: false }) do |f| %>
          <%= f.text_field :name, value: check_item.name, class: "checklist-edit-input", name: "checklist_item[name]", data: { inline_edit_target: "input", action: "keydown.enter->inline-edit#save keydown.esc->inline-edit#cancel" } %>
        <% end %>
        <%= link_to todo_list_todo_item_checklist_item_path(todo_list, item, check_item), data: { turbo_method: :delete, turbo_confirm: "Delete this item?" }, class: "checklist-remove" do %>
          <i class="fa-light fa-xmark" style="color: #A1A1AA;"></i>
        <% end %>
      </div>
    <% end %>
  </div>
  <%= form_with(url: todo_list_todo_item_checklist_items_path(todo_list, item), method: :post, class: "checklist-add-form", data: { checklist_add_target: "form", turbo: false }) do |f| %>
    <%= f.text_field :name, placeholder: "Add checklist item...", class: "checklist-add-input", name: "checklist_item[name]", data: { checklist_add_target: "input", action: "keydown.enter->checklist-add#save keydown.esc->checklist-add#hide" } %>
  <% end %>
</div>
