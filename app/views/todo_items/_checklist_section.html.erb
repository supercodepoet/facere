<div class="detail-section">
  <div class="detail-section-header">
    <wa-icon name="list-check" variant="thin" class="detail-section-icon" style="color: #8B5CF6;"></wa-icon>
    <span class="detail-section-title">Checklist</span>
    <% total = item.checklist_items.size %>
    <% done = item.checklist_items.count(&:completed?) %>
    <% if total > 0 %>
      <span class="checklist-progress-badge"><%= done %>/<%= total %></span>
    <% end %>
    <div class="detail-section-spacer"></div>
    <button class="detail-section-add-btn" onclick="document.getElementById('checklist-add-form-<%= item.id %>').style.display='flex'">
      <wa-icon name="plus" variant="thin"></wa-icon>
      Add
    </button>
  </div>
  <div class="checklist-items">
    <% item.checklist_items.each do |check_item| %>
      <div class="checklist-item #{'checklist-item--done' if check_item.completed?}">
        <%= button_to toggle_todo_list_todo_item_checklist_item_path(todo_list, item, check_item), method: :patch, class: "checklist-checkbox", data: { turbo: false } do %>
          <% if check_item.completed? %>
            <div class="checklist-box checklist-box--checked">
              <wa-icon name="check" style="color: #FFFFFF; font-size: 12px;"></wa-icon>
            </div>
          <% else %>
            <div class="checklist-box"></div>
          <% end %>
        <% end %>
        <span class="checklist-name #{'checklist-name--done' if check_item.completed?}"><%= check_item.name %></span>
        <%= button_to todo_list_todo_item_checklist_item_path(todo_list, item, check_item), method: :delete, class: "checklist-delete-btn", data: { turbo: false } do %>
          <wa-icon name="xmark" variant="thin" style="color: #A1A1AA;"></wa-icon>
        <% end %>
      </div>
    <% end %>
  </div>
  <%= form_with(url: todo_list_todo_item_checklist_items_path(todo_list, item), method: :post, id: "checklist-add-form-#{item.id}", class: "checklist-add-form", style: "display: none;", data: { turbo: false }) do |f| %>
    <%= f.text_field :name, placeholder: "Add checklist item...", class: "checklist-add-input", name: "checklist_item[name]", autofocus: true %>
    <%= f.submit "Add", class: "checklist-add-submit" %>
  <% end %>
</div>
