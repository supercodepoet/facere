<div class="detail-section">
  <div class="detail-section-header">
    <wa-icon name="paperclip" variant="thin" class="detail-section-icon"></wa-icon>
    <span class="detail-section-title">Attachments</span>
    <% if item.files.attached? %>
      <span class="attach-count-badge"><%= item.files.count %></span>
    <% end %>
    <div class="detail-section-spacer"></div>
    <label class="detail-section-add-btn attach-upload-label" for="attachment-upload-<%= item.id %>">
      <wa-icon name="cloud-arrow-up" variant="thin"></wa-icon>
      Upload
    </label>
  </div>
  <%= form_with(url: todo_list_todo_item_attachments_path(@todo_list || local_assigns[:todo_list], item), method: :post, multipart: true, class: "attach-upload-form", id: "attach-form-#{item.id}") do %>
    <input type="file" name="files[]" multiple id="attachment-upload-<%= item.id %>" class="attach-file-input" onchange="this.form.requestSubmit()">
  <% end %>
  <% if item.files.attached? %>
    <div class="attach-grid">
      <% item.files.each do |file| %>
        <div class="file-card">
          <wa-icon name="file" variant="thin" class="file-card-icon"></wa-icon>
          <span class="file-card-name"><%= file.filename %></span>
          <span class="file-card-size"><%= number_to_human_size(file.byte_size) %></span>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
