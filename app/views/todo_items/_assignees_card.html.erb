<div class="detail-card" id="item_assignees_<%= item.id %>">
  <div class="detail-card-header">
    <span class="detail-card-label">Assigned to</span>
    <span class="detail-card-spacer"></span>
  </div>
  <% if item.assignees.any? %>
    <% item.assignees.each do |assignee| %>
      <div class="assignee-row">
        <div class="assignee-avatar" style="background: #F472B6;">
          <%= assignee.initials %>
        </div>
        <div class="assignee-info">
          <span class="assignee-name"><%= assignee.name %></span>
        </div>
        <% if list_editor? %>
          <% item_assignee = item.item_assignees.find { |ia| ia.user_id == assignee.id } %>
          <% if item_assignee %>
            <%= button_to todo_list_todo_item_item_assignee_path(todo_list, item, item_assignee), method: :delete, class: "detail-card-icon-btn" do %>
              <i class="fa-solid fa-xmark" style="color: #A1A1AA;"></i>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <span class="detail-card-empty">No one assigned</span>
  <% end %>
  <% if list_editor? %>
    <% available_members = todo_list.all_members.where.not(id: item.assignees.map(&:id)) %>
    <% if available_members.any? %>
      <div class="assignee-add">
        <% available_members.each do |member| %>
          <%= form_with url: todo_list_todo_item_item_assignees_path(todo_list, item), method: :post, class: "assignee-add-form" do %>
            <input type="hidden" name="user_id" value="<%= member.id %>">
            <button type="submit" class="assignee-add-btn">
              <div class="assignee-avatar assignee-avatar-sm" style="background: #D1D5DB;">
                <%= member.initials %>
              </div>
              <span><%= member.name %></span>
              <i class="fa-light fa-plus" style="color: #8B5CF6; margin-left: auto;"></i>
            </button>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
