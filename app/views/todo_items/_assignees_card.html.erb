<div class="detail-card">
  <div class="detail-card-header">
    <span class="detail-card-label">Assigned to</span>
    <span class="detail-card-spacer"></span>
  </div>
  <% if item.assignees.any? %>
    <% item.assignees.each do |assignee| %>
      <div class="assignee-row">
        <div class="assignee-avatar" style="background: #F472B6;">
          <%= assignee.initials %>
        </div>
        <div class="assignee-info">
          <span class="assignee-name"><%= assignee.name %></span>
        </div>
      </div>
    <% end %>
  <% else %>
    <span class="detail-card-empty">No one assigned</span>
  <% end %>
</div>
