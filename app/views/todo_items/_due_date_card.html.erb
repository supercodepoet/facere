<div class="detail-card" data-controller="date-picker">
  <span class="detail-card-label">Due Date</span>
  <% if item.due_date.present? %>
    <div class="due-date-value">
      <div class="due-date-icon-wrap" style="background: #FEF3C7;">
        <i class="fa-solid fa-calendar-clock" style="color: #F59E0B;"></i>
      </div>
      <div class="due-date-text">
        <span class="due-date-day"><%= item.due_date_display %></span>
        <span class="due-date-countdown" style="color: <%= item.due_date_countdown_color %>;">
          <%= item.due_date_countdown %>
        </span>
      </div>
      <button type="button" class="detail-card-icon-btn" data-action="click->date-picker#openPicker">
        <i class="fa-light fa-pen" style="color: #A1A1AA;"></i>
      </button>
    </div>
  <% else %>
    <button type="button" class="detail-card-empty-btn" data-action="click->date-picker#openPicker">
      <i class="fa-light fa-calendar" style="color: #A1A1AA; margin-right: 6px;"></i>
      No due date set — click to add
    </button>
  <% end %>
  <%= form_with model: item, url: todo_list_todo_item_path(todo_list, item), method: :patch, data: { date_picker_target: "form", turbo: false } do |f| %>
    <%= f.date_field :due_date, class: "due-date-input", data: { date_picker_target: "input", action: "change->date-picker#submit" } %>
  <% end %>
</div>
