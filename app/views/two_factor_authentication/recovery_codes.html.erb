<div class="auth-form-container" data-controller="two-factor">
  <h1 class="auth-form-title" style="text-align: center;">Save Your Recovery Codes</h1>

  <wa-callout variant="warning" open style="margin-bottom: 20px;">
    <wa-icon slot="icon" name="triangle-exclamation" variant="thin"></wa-icon>
    These codes will only be shown once. Save them in a secure location.
  </wa-callout>

  <div style="padding: 16px; background: var(--color-zinc-50, #fafafa); border-radius: 12px; border: 1px solid var(--color-zinc-200, #e4e4e7); margin-bottom: 20px;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; font-family: monospace; font-size: 15px;" data-two-factor-target="codes">
      <% @recovery_codes.each do |code| %>
        <div style="padding: 6px 12px; background: white; border-radius: 6px; text-align: center;"><%= code %></div>
      <% end %>
    </div>
  </div>

  <wa-button
    variant="neutral"
    class="auth-primary-btn"
    style="margin-bottom: 12px;"
    data-action="click->two-factor#copyCodes"
  >
    <wa-icon slot="start" name="copy" variant="thin"></wa-icon>
    Copy All Codes
  </wa-button>

  <%= link_to root_path do %>
    <wa-button variant="brand" class="auth-primary-btn">
      I've Saved My Codes
    </wa-button>
  <% end %>
</div>
